# Example environment variables for local development
# Copy to `.env` and replace the value with your preferred submission endpoint.
# For local CSV API use: VITE_SUBMISSION_ENDPOINT=http://localhost:3001/api/submit
VITE_POWER_AUTOMATE_ENDPOINT=
VITE_SUBMISSION_ENDPOINT=

# Optional: absolute directory where CSV is stored by server.js
# Use this in hosted backends with persistent disks, e.g. Render: /var/data
CSV_DATA_DIR=
VITE_ENABLE_LOCAL_QUEUE=true

# Backend API config (`server.js`)
PORT=3001
ALLOWED_ORIGINS=http://localhost:5173
SUBMIT_RATE_LIMIT_PER_MIN=180
CSV_FLUSH_INTERVAL_MS=250
CSV_MAX_QUEUE_SIZE=10000
CSV_MAX_BATCH_SIZE=250
CSV_DEDUPE_WINDOW_MS=86400000
